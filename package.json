{
  "name": "data-lathe",
  "version": "0.7.3",
  "description": "A utility library for transforming and reshaping normalized data",
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "repository": {
    "url": "https://github.com/danielgamage/data-lathe"
  },
  "homepage": "https://github.com/danielgamage/data-lathe#readme",
  "bugs": {
    "url": "https://github.com/danielgamage/data-lathe/issues"
  },
  "exports": {
    ".": "./index.js"
  },
  "scripts": {
    "build": "rm -rf dist/* && rollup --config",
    "test": "vitest --watch",
    "test:ci": "vitest --ci",
    "copy-docs": "npm run build && cp index.js index.d.ts docs/node_modules/data-lathe/ && rm -rf docs/node_modules/.vite"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^9.0.1",
    "jest": "^29.1.2",
    "rollup": "^3.0.0",
    "rollup-plugin-typescript2": "^0.34.1",
    "typescript": "^4.8.4",
    "vitest": "^3.2.4"
  }
}
